#!/bin/bash

# TextLens OCR Launcher
# Fixes permissions and starts installer or app

# Get the directory this .app is in
APP_PATH="$0"
CONTENTS_DIR="$(cd "$(dirname "$APP_PATH")/.." && pwd)"
APP_DIR="$(cd "$CONTENTS_DIR/.." && pwd)"
INSTALL_DIR="$(dirname "$APP_DIR")"

# Fix permissions on all .command files in the same folder
chmod +x "$INSTALL_DIR"/*.command 2>/dev/null

# Check if already installed
DESKTOP="$HOME/Desktop"
APP_FOLDER="$DESKTOP/AzerbaijaniOCR"

if [ -d "$APP_FOLDER" ]; then
  # Already installed — launch the app
  osascript -e 'display dialog "TextLens OCR is already installed! Click OK to open the app." buttons {"OK"} default button "OK" with icon note with title "TextLens OCR"'
  open "$APP_FOLDER/Start OCR App.command"
else
  # First time — run installer
  osascript -e 'display dialog "Welcome to TextLens OCR!\n\nClick OK to begin installation.\nThis will take about 10-15 minutes." buttons {"OK"} default button "OK" with icon note with title "TextLens OCR"'
  open "$INSTALL_DIR/Install TextLens OCR.command"
fi
